# ========== SSH hacia el servidor de la BD ==========
DB_SSH_HOST=your-ssh-host
DB_SSH_PORT=22
DB_SSH_USER=your-ssh-user
DB_SSH_PASSWORD=your-ssh-password

# ========== Base de datos remota (vista DESDE el servidor SSH) ==========
# Normalmente MariaDB está en 127.0.0.1:3306 en el servidor.
DB_HOST_REMOTE=127.0.0.1
DB_PORT_REMOTE=3306

# Usuario y credenciales de MariaDB
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# ========== Opcional: logging de db_utils ==========
# Si pones 1, no imprime logs de conexión.
DB_UTILS_QUIET=0
